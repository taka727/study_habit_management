# Keep environment variables out of version control
.env
.env.docker
.env.example
/backend/.env.local
# Ignore node_modules
node_modules/
**/node_modules/

# Ignore package-lock files in node_modules
node_modules/**/*
package-lock.json

# Ignore log files
*.log
logs/

# Ignore temporary files
.tmp/
.cache/

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore development notes and hints
*_implementation_hints.md
auth_implementation_hints.md

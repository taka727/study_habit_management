// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status {
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model users {
  id                 Int       @id @default(autoincrement())
  name               String
  notification_onoff Boolean   @default(true)
  daily_goal_minutes Int       @default(120)
  language           String?   @default("ja") @db.VarChar(255)
  theme              String?   @default("light") @db.VarChar(255)
  login_name         String    @unique @db.VarChar(255)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?
}

model security_questions {
  id           Int       @id @default(autoincrement())
  question     String    @db.VarChar(255)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  security_question_answers security_question_answers[]
}

model security_question_answers {
  id           Int       @id @default(autoincrement())
  question_id  Int
  user_id      Int       @unique
  answer_salt  String    @db.VarChar(255)
  answer_hash  String    @db.VarChar(255)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  questions security_questions @relation(fields: [question_id], references: [id], onDelete: Cascade)
}

model tasks {
  id                 Int       @id @default(autoincrement())
  user_id            Int?
  parent_task_id     Int?
  name               String    @db.VarChar(50)
  description        String?   @db.VarChar(1000)
  schedule_date      DateTime?
  exec_expected_date DateTime?
  deadline           DateTime?
  status             Status    @default(TODO)
  duration_seconds   Int?
  category           String?   @db.VarChar(255)
  comment            String?   @db.VarChar(1000)
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt
  deleted_at         DateTime?

  history    study_histories[]
  task_goals task_goals[]

  @@index([status, deadline])
}

model study_histories {
  id               Int       @id @default(autoincrement())
  user_id          Int?
  task_id          Int?
  description      String?   @db.VarChar(1000)
  occurred_on      DateTime
  started_at       DateTime?
  ended_at         DateTime?
  duration_seconds Int?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt
  deleted_at       DateTime?

  task tasks? @relation(fields: [task_id], references: [id], onDelete: SetNull)

  @@index([occurred_on])
}

model goals {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  name          String    @db.VarChar(100)
  description   String?   @db.VarChar(1000)
  progress      Int       @default(0)
  goal_deadline DateTime
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt
  deleted_at    DateTime?

  task_goals task_goals[]

  @@index([goal_deadline])
}

model task_goals {
  id           Int       @id @default(autoincrement())
  goal_id      Int
  task_id      Int
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime?

  goal goals @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  task tasks @relation(fields: [task_id], references: [id], onDelete: Cascade)
}

model book_managements {
  id           Int        @id @default(autoincrement())
  user_id      Int?
  title        String     @db.VarChar(255)
  description  String?    @db.VarChar(1000)
  author       String?    @db.VarChar(255)
  status       BookStatus @default(TODO)
  rating       Int?
  created_at   DateTime   @default(now())
  updated_at   DateTime   @updatedAt
  deleted_at   DateTime?
}

enum BookStatus {
  TODO
  READING
  COMPLETED
}

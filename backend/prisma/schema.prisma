// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Status{
  TODO
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id              Int       @id @default(autoincrement())
  name            String
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleateed_at    DateTime?

  security_question_answer  security_question_answer[]
  task                      task[]
  history                   study_history[]
  goal                      goal[]
  book_management           book_management[]
}

model security_question{
  id              Int       @id @default(autoincrement())
  question        String    @db.VarChar(255)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleateed_at    DateTime?

  security_question_answer security_question_answer[]
}
model security_question_answer{
  id              Int       @id @default(autoincrement())
  question_id     Int       @unique
  user_id         Int       @unique
  answer_salt     String    @db.VarChar(255)
  answer_hash     String    @db.VarChar(255)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleateed_at    DateTime?

  user            User                @relation(fields: [user_id], references: [id],onDelete: Cascade)
  question        security_question   @relation(fields: [question_id], references: [id] , onDelete: Cascade)
}
model task{
  id                  Int       @id @default(autoincrement())
  user_id             Int       
  parent_task_id      Int?
  name                String    @db.VarChar(50)
  description         String?    @db.VarChar(1000)
  exec_expected_date  DateTime?
  deadline            DateTime?
  status              Status      @default(TODO)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
  deleateed_at        DateTime?

  user                User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  history             study_history[]
  task_golal          task_goal[]

  @@index             ([user_id,status,deadline])
}
model study_history{
  id                Int       @id @default(autoincrement())
  user_id           Int       @unique
  task_id           Int?      @unique
  description       String?    @db.VarChar(1000)
  occurreed_on      DateTime
  started_at        DateTime?
  ended_at          DateTime?
  duration_seconds  Int?
  created_at        DateTime  @default(now())
  updated_at        DateTime  @updatedAt
  deleateed_at      DateTime?

  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  task              task?      @relation(fields: [task_id], references: [id], onDelete: SetNull)
  @@index           ([user_id,occurreed_on])
}
model goal{
  id              Int       @id @default(autoincrement())
  user_id         Int       @unique
  goal_deadline   DateTime  
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleateed_at    DateTime?

  user            User      @relation(fields: [user_id], references:[id], onDelete: Cascade)
  task_goal       task_goal[]

  @@index         ([user_id,goal_deadline])
}
model task_goal{
  id              Int       @id @default(autoincrement())
  goal_id         Int
  task_id         Int
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleateed_at    DateTime?

  goal            goal      @relation(fields: [goal_id], references: [id], onDelete: Cascade)
  task            task      @relation(fields: [task_id], references: [id], onDelete: Cascade)
}
model book_management{
  id              Int       @id @default(autoincrement())
  user_id         Int       @unique
  title           String    @db.VarChar(255)
  desicription    String?    @db.VarChar(1000)
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  deleateed_at    DateTime?

  user            User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
}
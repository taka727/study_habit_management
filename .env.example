# Docker Compose 環境変数のサンプル
# このファイルを .env にコピーし、値を環境に合わせて設定してください。
#   cp .env.example .env
# 秘密情報（パスワード/JWT）は必ず安全な値に置き換えること。

# 環境設定
NODE_ENV=development

# アプリケーション設定
APP_NAME=study_habit
NETWORK_NAME=study_habit_network

# MySQL
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=study_habit_db
MYSQL_USER=study_user
MYSQL_PASSWORD=change-me-user-password
MYSQL_CHARSET=utf8mb4
MYSQL_COLLATION=utf8mb4_unicode_ci
MYSQL_PORT=3306
MYSQL_VOLUME_1=mysql_data
MYSQL_VOLUME_2=./mysql-init

# backend
BACKEND_DATABASE_URL=mysql://study_user:${MYSQL_PASSWORD}@mysql:3306/study_habit_db
BACKEND_JWT_SECRET=change-me-jwt-secret
BACKEND_NODE_ENV=development
BACKEND_DB_HOST=mysql
BACKEND_DB_USER=root
BACKEND_DB_PASSWORD=${MYSQL_ROOT_PASSWORD}
BACKEND_DB_NAME=study_habit_db
BACKEND_DB_PORT=3306
BACKEND_PORT=3000
BACKEND_USER_ID=study_user
BACKEND_VOLUME_1=./backend

# frontend
FRONTEND_VITE_API_URL=http://localhost:3000
FRONTEND_PORT=5173
FRONTEND_HOST=0.0.0.0
FRONTEND_VOLUME_1=./frontend
